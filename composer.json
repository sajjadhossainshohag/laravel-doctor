{
  "name": "sajjadhossainshohag/laravel-doctor",
  "description": "Code Health Checker for Laravel — catch broken routes, missing views, schema mismatches, and runtime errors before deployment.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "health-check",
    "code-quality",
    "static-analysis"
  ],
  "authors": [
    {
      "name": "Sajjad Hossain Shohag",
      "email": "sajjadhossainshohagbd@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/contracts": "^11.0|^12.0|^13.0",
    "illuminate/http": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0",
    "illuminate/routing": "^11.0|^12.0|^13.0",
    "illuminate/cache": "^11.0|^12.0|^13.0",
    "nikic/php-parser": "^5.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "orchestra/testbench": "^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "SajjadHossain\\Doctor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SajjadHossain\\Doctor\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SajjadHossain\\Doctor\\DoctorServiceProvider"
      ],
      "aliases": {
        "Doctor": "SajjadHossain\\Doctor\\Facades\\Doctor"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
