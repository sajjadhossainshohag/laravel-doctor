{
    "name": "sajjadhossain/laravel-doctor",
    "description": "Code Health Checker for Laravel — catch broken routes, missing views, schema mismatches, and runtime errors before deployment.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "health-check", "code-quality", "static-analysis"],
    "authors": [
        {
            "name": "Sajjad Hossain",
            "email": "sajjad@example.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "11.0",
        "illuminate/console": "13.0",
        "illuminate/contracts": "13.0",
        "illuminate/http": "13.0",
        "illuminate/support": "13.0",
        "illuminate/database": "13.0",
        "illuminate/view": "13.0",
        "illuminate/routing": "13.0",
        "illuminate/cache": "13.0"
    },
    "autoload": {
        "psr-4": {
            "SajjadHossain\\Doctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SajjadHossain\\Doctor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SajjadHossain\\Doctor\\DoctorServiceProvider"
            ],
            "aliases": {
                "Doctor": "SajjadHossain\\Doctor\\Facades\\Doctor"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
