{
  "name": "sajjadhossainshohag/laravel-doctor",
  "description": "Code Health Checker for Laravel — catch broken routes, missing views, schema mismatches, and runtime errors before deployment.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "health-check",
    "code-quality",
    "static-analysis"
  ],
  "authors": [
    {
      "name": "Sajjad Hossain Shohag",
      "email": "sajjadhossainshohagbd@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
    "nikic/php-parser": "^5.0"
  },
  "suggest": {
    "laravel/agent-detector": "^2.0 — Auto-detect AI coding agents (requires PHP 8.2+) for agent-friendly output format (required for automatic --format=agent detection)."
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "SajjadHossain\\Doctor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SajjadHossain\\Doctor\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SajjadHossain\\Doctor\\DoctorServiceProvider"
      ],
      "aliases": {
        "Doctor": "SajjadHossain\\Doctor\\Facades\\Doctor"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
